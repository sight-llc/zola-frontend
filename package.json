{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:capacitor": "vite build --config vite.config.capacitor.ts",
    "dev:capacitor": "vite --config vite.config.capacitor.ts --port 5173 --host 0.0.0.0 --strictPort",
    "dev:capacitor:port": "lsof -nP -iTCP:5173 -sTCP:LISTEN",
    "icons:android": "capacitor-assets generate --android",
    "android": "cap run android",
    "android:live": "cap run android -l --host localhost --port 5173 --forwardPorts 5173:5173",
    "android:devices": "adb devices -l",
    "android:adb-reset": "adb kill-server && adb start-server && adb reconnect offline && adb devices -l",
    "android:live:fresh": "npm run android:adb-reset && npm run android:live",
    "android:install": "cap sync android && cd android && ./gradlew assembleDebug && cd .. && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:launch": "adb shell am start -n com.sight.zola/.MainActivity",
    "android:run": "npm run android:install && npm run android:launch",
    "android:build": "npm run build:capacitor && cap sync android && cap run android",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^7.6.7",
